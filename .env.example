# Copy this file to .env and adjust values for your machine.
# Do not commit .env to source control.
#
#   cp .env.example .env        (Linux / macOS)
#   copy .env.example .env      (Windows)

# -----------------------------------------------------------------------------
# PostgreSQL (Docker Compose)
# -----------------------------------------------------------------------------
POSTGRES_DB=expense_manager
POSTGRES_USER=expense_manager
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Spring Boot datasource (local profile)
# Must match PostgreSQL settings above when running the app on the host.
# -----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/expense_manager
SPRING_DATASOURCE_USERNAME=expense_manager
SPRING_DATASOURCE_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Reserved for Phase 2+ (Identity module) — do not set until required
# -----------------------------------------------------------------------------
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
